---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { MAX_DISPLAY_NAME_LENGTH, getSafeDisplayName } from '../lib/profile';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { data: participant } = await supabase
  .from('participants')
  .select('email, display_name, avatar_url, email_notifications_enabled')
  .eq('email', user.email)
  .single();

const error = Astro.url.searchParams.get('error') ?? '';
const success = Astro.url.searchParams.get('success') ?? '';
const errorMessages: Record<string, string> = {
  display_name_too_long: 'Username must be 20 characters or less.',
  upload_failed: 'Avatar upload failed. Try again.',
  invalid_image: 'Please upload an image file for your avatar.',
  db_error: 'Database error. Please try again.',
};
const safeDisplayName = getSafeDisplayName(participant?.display_name, participant?.email || user.email);
const emailNotificationsEnabled = participant?.email_notifications_enabled !== false;
---
<Layout title="Profile — The Trip Culling Game">
  <div class="container" style="max-width:760px">
    <div class="game-title">
      <span class="line-small">the <span class="word-trip">trip</span></span>
      <span class="line-main">CULLING GAME</span>
    </div>

    <h2 class="section-title">PROFILE</h2>
    {error && <div class="alert alert-error">{errorMessages[error] ?? error}</div>}
    {success === 'true' && <div class="alert alert-success">Profile updated.</div>}

    <form method="POST" action="/api/update-profile" enctype="multipart/form-data" class="pixel-box" style="padding:24px;">
      <div class="profile-preview">
        <img class="profile-avatar-large" src={participant?.avatar_url || '/default-avatar.webp'} alt={safeDisplayName || participant?.email || 'Profile avatar'} />
      </div>

      <div class="form-group">
        <label class="form-label" for="display_name">USERNAME</label>
        <input
          class="form-input"
          type="text"
          id="display_name"
          name="display_name"
          maxlength={MAX_DISPLAY_NAME_LENGTH}
          value={safeDisplayName}
          data-char-count
          data-char-max={MAX_DISPLAY_NAME_LENGTH}
        />
        <p class="form-hint"><span data-char-output>{safeDisplayName.length}</span> / {MAX_DISPLAY_NAME_LENGTH}</p>
      </div>

      <div class="form-group">
        <label class="form-label" for="avatar">PROFILE PHOTO</label>
        <label class="form-file-label" for="avatar" id="avatar-label">CHOOSE AVATAR</label>
        <input class="form-file-input" type="file" id="avatar" name="avatar" accept="image/*" />
        <p class="form-hint">Square crop. Default avatar is used if you never upload one.</p>
      </div>

      <div class="form-group">
        <label class="photo-slot-remove admin-inline-toggle">
          <input type="checkbox" name="email_notifications_enabled" checked={emailNotificationsEnabled} />
          EMAIL NOTIFICATIONS
        </label>
        <p class="form-hint">Controls phase updates, restart/draw mails, winner announcements, and destination-removal emails.</p>
      </div>

      <button type="submit" class="btn btn-primary">SAVE PROFILE</button>
    </form>
  </div>
</Layout>

<script>
  const avatarInput = document.getElementById('avatar') as HTMLInputElement | null;
  const avatarLabel = document.getElementById('avatar-label');
  const avatarPreview = document.querySelector('.profile-avatar-large') as HTMLImageElement | null;

  avatarInput?.addEventListener('change', () => {
    const file = avatarInput.files?.[0];
    if (!file || !avatarPreview || !avatarLabel) return;
    avatarLabel.textContent = file.name;
    const url = URL.createObjectURL(file);
    avatarPreview.src = url;
    avatarPreview.onload = () => URL.revokeObjectURL(url);
  });

  document.querySelectorAll('[data-char-count]').forEach(input => {
    const updateCount = () => {
      const field = input as HTMLInputElement;
      const output = field.parentElement?.querySelector('[data-char-output]');
      if (output) output.textContent = String(field.value.length);
    };
    input.addEventListener('input', updateCount);
    updateCount();
  });
</script>
