# Supabase — Settings → API in your project dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Resend — resend.com → API Keys
RESEND_API_KEY=re_your-api-key

# Public URL of the app (used in emails and links — no trailing slash)
SITE_URL=https://the-trip-culling-game.lucaskruger.com

# Comma-separated emails that become Game Masters on first seed
# Game Masters have super admin privileges and can manage other admins
GAME_MASTER_EMAILS=you@example.com
